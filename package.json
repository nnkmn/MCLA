{
  "name": "mcla",
  "version": "0.4.2",
  "description": "MCLA - 一个现代化的 Minecraft 启动器，支持微软正版登录、版本管理、Mod 下载",
  "main": "./out/main/index.js",
  "author": "EccenTri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nnkmn/MCLA"
  },
  "scripts": {
    "dev": "npm run build && cross-env NODE_ENV=development electron .",
    "dev:hot": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "postbuild": "node scripts/fix-is.js",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/ electron/"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.0.0",
    "electron-log": "^5.0.0",
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^5.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.1",
    "png-to-ico": "^3.0.1",
    "pptxgenjs": "^4.0.1",
    "prettier": "^3.8.3",
    "sass": "^1.77.0",
    "sass-embedded": "^1.99.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.1",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.4.0"
  }
}
