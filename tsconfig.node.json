{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./out",
    "declaration": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "downlevelIteration": true
  },
  "include": [
    "electron.vite.config.ts",
    "electron/**/*.ts"
  ]
}
